        <svg width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke-linejoin="round"
             :attr:fill="isFav() ? '#FF3E54' : 'none'"
             :attr:stroke="isFav() ? '#FF3E54' : 'currentColor'"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span :text="favLabel">Save</span>
      </button>
    </div>
  </div>

  <!-- Gallery -->
  <div class="gallery-grid">
    @foreach (galleryItems as idx => src)
