      </section>
    </div>

    <!-- Booking sidebar -->
    <aside class="book-sidebar">
      <div class="p-6 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]" style="box-shadow: 0 24px 48px -12px rgba(0,0,0,0.18)">
        <div class="flex items-baseline justify-between mb-4">
          <div>
            <span class="font-bold text-3xl tabular">${{ car.price }}</span>
            <span class="text-sm text-[color:var(--text-muted)]"> / day</span>
            @if (car.originalPrice)
              <span class="ml-2 line-through text-[0.9375rem] tabular text-[color:var(--text-muted)]">${{ car.originalPrice }}</span>
            @endif
          </div>
          @if (car.instantBook)
            <span class="inline-flex gap-1 items-center px-2 py-0.5 font-medium text-[#10B981] text-[0.6875rem] bg-[rgba(16,185,129,0.12)] border border-[rgba(16,185,129,0.25)] rounded-full">⚡ Instant</span>
          @endif
        </div>

        <!-- Dates bind to fromDate/toDate signals via x-model. `min` on start
             prevents booking in the past; `:attr:min` on end binds to fromDate
             so end-before-start is unselectable in the native picker. -->
        <div class="grid overflow-hidden grid-cols-2 mb-2 border rounded-xl border-[color:var(--border)]">
          <label class="block p-3 border-r cursor-pointer border-[color:var(--border)]">
            <span class="block font-semibold text-[0.6875rem] tracking-wider uppercase text-[color:var(--text-muted)]">Trip start</span>
            <input type="date" x-model="fromDate" :attr:min="todayStr" class="py-0.5 w-full text-sm bg-transparent border-0 outline-0 text-[color:var(--text)]">
          </label>
          <label class="block p-3 cursor-pointer">
            <span class="block font-semibold text-[0.6875rem] tracking-wider uppercase text-[color:var(--text-muted)]">Trip end</span>
            <input type="date" x-model="toDate" :attr:min="fromDate" class="py-0.5 w-full text-sm bg-transparent border-0 outline-0 text-[color:var(--text)]">
          </label>
        </div>
        <p class="m-0 mb-2 text-[#FF3E54] text-[0.8125rem]" :show="dateError()" :text="dateError"></p>

        <div class="grid overflow-hidden grid-cols-2 mb-4 border rounded-xl border-[color:var(--border)]">
          <label class="block p-3 border-r cursor-pointer border-[color:var(--border)]">
            <span class="block font-semibold text-[0.6875rem] tracking-wider uppercase text-[color:var(--text-muted)]">Pick up at</span>
            <select x-model="pickupTime" class="py-0.5 w-full text-sm bg-transparent border-0 outline-0 text-[color:var(--text)]">
              @foreach (pickupTimes as t)
                <option value="{{ t }}">{{ t }}</option>
              @endforeach
            </select>
          </label>
          <label class="block p-3 cursor-pointer">
            <span class="block font-semibold text-[0.6875rem] tracking-wider uppercase text-[color:var(--text-muted)]">Return at</span>
            <select x-model="returnTime" class="py-0.5 w-full text-sm bg-transparent border-0 outline-0 text-[color:var(--text)]">
              @foreach (pickupTimes as t)
                <option value="{{ t }}">{{ t }}</option>
              @endforeach
            </select>
          </label>
        </div>

        <!-- Price breakdown — every number is a :text binding -->
        <div class="flex flex-col gap-2 py-4 text-sm border-t border-[color:var(--border)]">
          <div class="flex justify-between">
            <span class="text-[color:var(--text-muted)]">${{ car.price }} × <span :text="days">3</span> days</span>
            <span :text="subtotalLabel" class="tabular">${{ car.price * 3 }}.00</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[color:var(--text-muted)]">Trip fee (10%)</span>
            <span :text="feeLabel" class="tabular">${{ (car.price * 3 * 0.1).toFixed(2) }}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[color:var(--text-muted)]">Protection plan <span class="text-xs text-[color:var(--text-muted)]">(Minimum)</span></span>
            <span :text="protLabel" class="tabular">${{ (car.price * 3 * 0.15).toFixed(2) }}</span>
          </div>
          <div class="flex justify-between pt-3 font-bold text-base border-t border-[color:var(--border)]">
            <span>Total</span>
            <span :text="totalLabel" class="tabular">${{ (car.price * 3 * 1.25).toFixed(2) }}</span>
          </div>
        </div>

        <!-- Anchor href is reactive via :attr:href — builds `/book/:id?from=…` from signals -->
        <a :attr:href="continueHref()"
           class="inline-flex gap-2 items-center justify-center mt-2 px-5 py-3.5 w-full font-semibold text-[0.9375rem] text-white bg-[#FF3E54] hover:bg-[#e63349] rounded-xl transition-all hover:-translate-y-px"
           style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)">
          Continue to book
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <p class="m-0 mt-3 text-[0.8125rem] text-center text-[color:var(--text-muted)]">You won't be charged yet</p>
      </div>

      <div class="flex gap-3 mt-4 p-5 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF3E54" stroke-width="1.75" class="flex-shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <p class="m-0 font-semibold text-[0.9375rem]">Every trip is protected</p>
          <p class="m-0 mt-1 leading-relaxed text-[0.8125rem] text-[color:var(--text-muted)]">Liability insurance up to $750K. 24/7 customer support. Free cancellation up to 24 hours.</p>
        </div>
      </div>
    </aside>
  </div>

  <!-- Similar cars -->
  <section class="mt-16">
    <h2 class="m-0 mb-6 text-3xl serif">You might also like</h2>
    <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 md:grid-cols-4">
      @foreach (similar as sc)
        @component('CarCard', { car: sc })
        @endcomponent
      @endforeach
    </div>
  </section>
</div>

<!-- Lightbox: :show drives display, :attr:src picks the current image from GALLERY -->
<div class="fixed inset-0 z-[200] items-center justify-center p-8"
     style="background: rgba(0,0,0,0.92); display: flex"
     :show="lightboxIdx() !== null"
     @click="closeLightbox()">
  <button class="absolute right-6 top-6 h-10 w-10 text-2xl text-white bg-white/10 border-0 rounded-full cursor-pointer" @click.stop="closeLightbox()">×</button>
  <img class="max-h-full max-w-full" :attr:src="lightboxSrc()">
</div>

<script client>
  const PRICE = {{ car.price }}
  const CAR_ID = {{ car.id }}
  const GALLERY = {{ car.gallery }}
  const DEFAULT_FROM = '{{ fmtDate(defaultFrom) }}'
  const DEFAULT_TO = '{{ fmtDate(defaultTo) }}'

  const favorites = useStore('favorites')

  // ── Reactive state ──
  const activeTab   = state('overview')
  const fromDate    = state(DEFAULT_FROM)
  const toDate      = state(DEFAULT_TO)
  const pickupTime  = state('10:00')
  const returnTime  = state('10:00')
  const lightboxIdx = state(null)

  // Today's date in YYYY-MM-DD format — feeds the `min` attribute on the
  // trip-start input so past dates can't be selected. A derived signal
  // would re-evaluate only on date changes, but Date.now() changes by the
  // millisecond, so a plain computed value at mount is fine here.
  const todayStr = (() => {
    const d = new Date()
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0')
  })()

  // Inline date validation — surfaces a friendly message under the picker
  // if the user somehow lands on an invalid range (e.g. end before start
  // due to timezone math or a manual keyboard edit).
  const dateError = derived(() => {
    const f = fromDate(), t = toDate()
    if (!f || !t) return ''
    if (new Date(t) < new Date(f)) return 'Return date must be on or after pickup.'
    if (new Date(f) < new Date(todayStr)) return 'Pickup date can\'t be in the past.'
    return ''
  })

  // Store signals propagate through derived() directly — reading favorites.ids()
  // inside the computation subscribes it to ids changes.
  const isFav     = derived(() => { favorites.ids(); return favorites.has(CAR_ID) })
  const favLabel  = derived(() => isFav() ? 'Saved' : 'Save')

  const days = derived(() => {
    const ms = Math.max(0, new Date(toDate()) - new Date(fromDate()))
    return Math.max(1, Math.ceil(ms / 86400000))
  })
  const subtotal = derived(() => PRICE * days())
  const fee      = derived(() => subtotal() * 0.1)
  const protection = derived(() => subtotal() * 0.15)
  const total    = derived(() => subtotal() + fee() + protection())

  const fmtMoney = n => '$' + n.toFixed(2)
  const subtotalLabel = derived(() => fmtMoney(subtotal()))
  const feeLabel      = derived(() => fmtMoney(fee()))
  const protLabel     = derived(() => fmtMoney(protection()))
  const totalLabel    = derived(() => fmtMoney(total()))

  const continueHref = derived(() =>
    '/book/' + CAR_ID + '?from=' + fromDate() + '&to=' + toDate()
    + '&ft=' + pickupTime() + '&tt=' + returnTime()
  )

  const lightboxSrc = derived(() => lightboxIdx() === null ? '' : GALLERY[lightboxIdx()])

  // ── Actions ──
  function toggleFav() {
    favorites.toggle(CAR_ID)
    window._toast && window._toast(favorites.has(CAR_ID) ? 'Saved to favorites' : 'Removed from favorites', 'success')
  }

  function share() {
    const url = location.href
    if (navigator.share) navigator.share({ url, title: document.title }).catch(() => {})
    else { navigator.clipboard && navigator.clipboard.writeText(url); window._toast('Link copied', 'success') }
  }

  function messageHost() { window._toast && window._toast('Message sent to ' + {{ car.host.name.split(' ')[0] }}, 'success') }
  function loadMoreReviews() { window._toast && window._toast('Loaded more reviews', 'info') }

  function openLightbox(idx) { lightboxIdx.set(idx); document.body.style.overflow = 'hidden' }
  function closeLightbox()   { lightboxIdx.set(null); document.body.style.overflow = '' }

  // Esc closes the lightbox. The one piece of true global-keyboard handling.
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeLightbox() })
</script>

@endsection
