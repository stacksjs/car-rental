          @foreach (car.badges as badge)
            <span class="inline-flex gap-1.5 items-center px-2.5 py-1.5 font-medium text-[#FF3E54] text-xs bg-[rgba(255,62,84,0.1)] border border-[rgba(255,62,84,0.25)] rounded-full">{{ badge }}</span>
          @endforeach
        @endif
      </div>
    </div>
    <div class="flex gap-2">
      <button class="inline-flex gap-2 items-center px-3.5 py-2 font-semibold text-[0.8125rem] bg-transparent border rounded-xl transition-colors border-[color:var(--border-strong)] text-[color:var(--text)] hover:bg-[color:var(--bg-subtle)]" @click="share()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>
        Share
