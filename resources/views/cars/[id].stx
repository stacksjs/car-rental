             loading="{{ idx === 0 ? 'eager' : 'lazy' }}" decoding="async"
             fetchpriority="{{ idx === 0 ? 'high' : 'auto' }}">
      </div>
    @endforeach
  </div>

  <div class="grid gap-12 grid-cols-1 items-start md:grid-cols-[1fr_380px] mt-10">

    <!-- Left column -->
    <div>
      <!-- Host strip -->
      <section class="flex flex-wrap gap-4 items-center justify-between p-6 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
