<script server>
import { cars, getCar } from '../../data/cars'

const id = params?.id || 'tesla-model-3-2024'
const car = getCar(id) || cars[0]
const pageTitle = car.year + ' ' + car.make + ' ' + car.model + ' · Drivly'
const pageDescription = car.description.slice(0, 160)
const activePage = 'search'

// Route config: validator rejects unknown car IDs (→ 404) at the dev-server
// level before we even build the page. Runs per request for dynamic routes.
definePageMeta({
  validate({ params }) {
    return getCar(params.id) !== undefined
  },
})

// Per-car SEO. The gallery's first photo doubles as the OG image so link
// previews on Slack/Twitter show the actual car.
useSeoMeta({
  title: pageTitle,
  description: pageDescription,
  ogTitle: car.year + ' ' + car.make + ' ' + car.model,
  ogDescription: pageDescription,
  ogImage: car.gallery[0] || car.image,
  ogType: 'product',
  ogUrl: 'https://drivly.example/cars/' + car.id,
  twitterCard: 'summary_large_image',
  twitterTitle: pageTitle,
  twitterImage: car.gallery[0] || car.image,
})

const similar = cars.filter(c => c.id !== car.id && c.category === car.category).slice(0, 4)
if (similar.length < 4) {
  for (const c of cars) {
    if (similar.length >= 4) break
    if (c.id !== car.id && !similar.find(s => s.id === c.id)) similar.push(c)
  }
}

const ratingPct = {
  cleanliness: 4.9, maintenance: 4.95, communication: 4.92, convenience: 4.88, accuracy: 4.94,
}
const ratingMetricEntries = Object.entries(ratingPct)

const defaultFrom = new Date()
defaultFrom.setDate(defaultFrom.getDate() + 3)
const defaultTo = new Date()
defaultTo.setDate(defaultTo.getDate() + 6)
const fmtDate = d => d.toISOString().slice(0, 10)

const tripRules = [
  'No smoking — $250 cleaning fee if violated',
  'Pets welcome with advance notice',
  'Off-road driving requires approval',
  'Return with same fuel/charge level',
  'Max 200 miles/day (extra miles: $0.40/mi)',
  'Valid driver\'s license required',
]

const pickupTimes = ['08:00', '09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00']
const galleryItems = car.gallery.filter((_, i) => i < 5)

const tabs = [
  { id: 'overview', label: 'Overview' },
  { id: 'features', label: 'Features' },
  { id: 'rules', label: 'Rules' },
  { id: 'reviews', label: 'Reviews (' + car.reviewCount + ')' },
  { id: 'location', label: 'Location' },
]
</script>

@extends('layouts/app.stx')

@push('styles')
  .gallery-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 0.5rem; aspect-ratio: 16/9; border-radius: 1.5rem; overflow: hidden; }
  .gallery-grid > *:nth-child(1) { grid-row: span 2; }
  .gallery-cell { width: 100%; height: 100%; cursor: pointer; overflow: hidden; background: var(--bg-muted); }
  .gallery-cell img { width: 100%; height: 100%; object-fit: cover; transition: opacity 180ms, transform 400ms; }
  .gallery-cell:hover img { opacity: 0.9; transform: scale(1.04); }
  @media (max-width: 720px) {
    .gallery-grid { grid-template-columns: 1fr; grid-template-rows: auto; aspect-ratio: auto; }
    .gallery-grid > * { aspect-ratio: 16/10; }
    .gallery-grid > *:nth-child(1) { grid-row: auto; }
    .gallery-grid > *:nth-child(n+4) { display: none; }
  }
  .book-sidebar { position: sticky; top: 96px; }
  @media (max-width: 980px) { .book-sidebar { position: static; top: auto; } }
@endpush

@section('content')
<div class="mx-auto pb-16 px-6 py-6 max-w-[1280px]">

