        <div class="flex gap-3 items-center mb-8">
          <span class="font-bold text-4xl">{{ car.rating }}</span>
          <div>
            @component('Rating', { rating: car.rating })
            @endcomponent
            <p class="m-0 mt-1 text-sm text-[color:var(--text-muted)]">{{ car.reviewCount }} reviews</p>
          </div>
