  <nav class="flex gap-2 items-center mb-4 text-[0.8125rem] text-[color:var(--text-muted)]">
    <StxLink to="/" class="text-[color:var(--text-muted)] hover:text-[color:var(--text)]">Home</StxLink>
    <span>›</span>
    <StxLink to="/search" class="text-[color:var(--text-muted)] hover:text-[color:var(--text)]">Cars in {{ car.location.split(',')[0] }}</StxLink>
    <span>›</span>
    <span class="text-[color:var(--text)]">{{ car.year }} {{ car.make }} {{ car.model }}</span>
