              @endif
            </p>
            <p class="m-0 mt-0.5 text-[0.8125rem] text-[color:var(--text-muted)]">{{ car.host.trips }} trips · Joined {{ car.host.joined }} · Typically replies {{ car.host.responseTime }}</p>
          </div>
        </div>
        <button class="px-3.5 py-2 font-semibold text-[0.8125rem] border rounded-xl transition-colors bg-[color:var(--bg-subtle)] border-[color:var(--border)] text-[color:var(--text)] hover:bg-[color:var(--bg-muted)]"
