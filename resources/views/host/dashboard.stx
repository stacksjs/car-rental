      <p class="m-0 text-[color:var(--text-muted)]">Welcome back, Alejandro. Here's how things are going.</p>
    </div>
    <div class="flex gap-2 items-center">
      <select class="px-3 py-2 text-sm border rounded-lg bg-[color:var(--input-bg)] border-[color:var(--border)] text-[color:var(--text)]">
        <option>Last 12 months</option><option>Last 30 days</option><option>Year to date</option>
      </select>
      <StxLink to="/host/list" class="inline-flex gap-1.5 items-center px-4 py-2 font-semibold text-sm text-white bg-[#FF3E54] hover:bg-[#e63349] rounded-lg transition-colors">+ Add listing</StxLink>
    </div>
