                        :text="b.status"></span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Listings -->
    <div class="p-6 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
      <div class="flex items-center justify-between mb-4">
        <h2 class="m-0 font-bold text-lg">Your listings</h2>
        <StxLink to="/host/list" class="inline-flex items-center px-3 py-1.5 font-semibold text-xs border rounded-lg transition-colors border-[color:var(--border-strong)] text-[color:var(--text)] hover:bg-[color:var(--bg-subtle)]">+ Add new</StxLink>
      </div>
      <p :show="myCars().length === 0" class="m-0 text-sm text-[color:var(--text-muted)]">You haven't listed any cars yet.</p>
      <div class="flex flex-col gap-3">
        <template :foreach="car of myCars()">
          <a :href="'/cars/' + car.slug" class="flex gap-4 items-center p-3.5 border rounded-xl transition-transform bg-[color:var(--bg-subtle)] border-[color:var(--border)] hover:-translate-y-px">
            <img :src="car.image" class="object-cover rounded-lg" style="width: 88px; height: 64px">
            <div class="flex-1 min-w-0">
              <p class="m-0 font-semibold text-[0.9375rem]" :text="car.year + ' ' + car.make + ' ' + car.model"></p>
              <p class="m-0 mt-1 text-[0.8125rem] text-[color:var(--text-muted)]" :text="'$' + Number(car.daily_rate || 0) + '/day · ' + Number(car.rating || 0).toFixed(2) + '★ (' + (car.review_count ?? 0) + ')'"></p>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 font-medium text-[0.6875rem] rounded-full"
                  :class="car.status === 'active' ? 'text-emerald-500 bg-emerald-500/10 border border-emerald-500/25' : 'text-[color:var(--text-muted)] bg-[color:var(--bg-muted)] border border-[color:var(--border)]'"
                  :text="car.status === 'active' ? 'Live' : car.status"></span>
          </a>
        </template>
      </div>
    </div>
  </div>

</div>

<script client>
  const loading = state(true)
  const authed = state(false)
  const notAHost = state(false)
  const kpis = state({})
  const upcoming = state([])
  const myCars = state([])
  const chargesEnabled = state(false)
  const payoutsEnabled = state(false)
  const needsPayoutSetup = derived(() => !chargesEnabled() || !payoutsEnabled())

  async function load() {
    loading.set(true)
    const token = localStorage.getItem('drivly-token')
    if (!token) { authed.set(false); loading.set(false); return }
    authed.set(true)
    try {
      const res = await fetch('/api/host/dashboard', { headers: { Authorization: 'Bearer ' + token } })
      if (res.status === 403) { notAHost.set(true); return }
      if (!res.ok) throw new Error('dashboard fetch failed')
      const body = await res.json()
      if (body?.empty) { notAHost.set(true); return }
      notAHost.set(false)
      kpis.set(body.kpis || {})
      upcoming.set(body.upcoming || [])
      myCars.set((body.cars || []).map(c => c._attributes ?? c))
      chargesEnabled.set(!!body.chargesEnabled)
      payoutsEnabled.set(!!body.payoutsEnabled)
    }
    catch {
      kpis.set({}); upcoming.set([]); myCars.set([])
    }
    finally { loading.set(false) }
  }

  async function applyAsHost() {
    const token = localStorage.getItem('drivly-token')
    if (!token) return
    try {
      const r = await fetch('/api/host/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
        body: '{}',
      })
      if (r.ok) {
        window._toast && window._toast('You\'re now a host!', 'success')
        load()
      }
    }
    catch { window._toast && window._toast('Could not apply', 'error') }
  }

  async function startStripeOnboarding() {
    const token = localStorage.getItem('drivly-token')
    if (!token) return
    try {
      const r = await fetch('/api/host/connect/onboard', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
        body: '{}',
      })
      if (!r.ok) throw new Error()
      const body = await r.json()
      if (body?.url) location.href = body.url
    }
    catch { window._toast && window._toast('Stripe onboarding unavailable', 'error') }
  }

  effect(() => { load() })
</script>

@endsection
