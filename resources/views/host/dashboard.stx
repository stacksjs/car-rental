              <div class="h-full rounded-full" style="width: {{ item.pct }}%; background: {{ item.color }}"></div>
            </div>
          </div>
        @endforeach
      </div>
      <div class="mt-6 pt-4 text-sm border-t border-[color:var(--border)]">
        <p class="m-0 mb-1 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Next payout</p>
