        <p class="m-0 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">{{ kpi.label }}</p>
        <p class="m-0 mb-1 mt-2.5 font-bold text-3xl tabular">{{ kpi.value }}</p>
        <span class="inline-flex gap-1 items-center px-2 py-0.5 font-medium text-[0.6875rem] text-emerald-500 bg-emerald-500/10 border border-emerald-500/25 rounded-full">↑ {{ kpi.delta }}</span>
      </div>
    @endforeach
  </div>

  <!-- Charts + bookings -->
  <div class="grid gap-6 grid-cols-1 md:grid-cols-[2fr_1fr] mb-8">
    <div class="p-6 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
      <div class="flex items-center justify-between mb-5">
        <div>
          <h2 class="m-0 font-bold text-lg">Earnings over time</h2>
          <p class="m-0 mt-1 text-sm text-[color:var(--text-muted)]">Last 12 months · Total <span class="font-semibold tabular text-[color:var(--text)]">${{ totalE.toLocaleString() }}</span></p>
        </div>
      </div>
      <svg viewBox="0 0 600 220" class="h-[220px] w-full">
        <defs>
          <linearGradient id="earnGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#FF3E54" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#FF3E54" stop-opacity="0"/>
          </linearGradient>
        </defs>
        @foreach (gridLines as y)
          <line x1="40" y1="{{ y }}" x2="590" y2="{{ y }}" stroke="var(--border)" stroke-dasharray="2 4"/>
        @endforeach
        <polygon points="{{ areaPointsStr }}" fill="url(#earnGrad)"/>
        <polyline points="{{ chartPointsStr }}" fill="none" stroke="#FF3E54" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        @foreach (chartDots as dot)
          <circle cx="{{ dot.cx }}" cy="{{ dot.cy }}" r="3.5" fill="white" stroke="#FF3E54" stroke-width="2"/>
          <text x="{{ dot.cx }}" y="205" text-anchor="middle" font-size="10" fill="var(--text-muted)" font-family="Inter, sans-serif">{{ dot.label }}</text>
        @endforeach
      </svg>
    </div>

    <div class="p-6 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
      <h2 class="m-0 mb-4 font-bold text-lg">Performance mix</h2>
      <div class="flex flex-col gap-4">
        @foreach (perfMix as item)
          <div>
            <div class="flex justify-between mb-1.5 text-[0.8125rem]">
