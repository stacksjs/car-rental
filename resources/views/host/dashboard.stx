      <h2 class="m-0 font-bold text-lg">Upcoming bookings</h2>
      <a href="#" class="font-semibold text-[#FF3E54] text-[0.8125rem]">View all</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-[color:var(--border)]">
            <th class="px-3 py-2.5 font-semibold text-left text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Car</th>
            <th class="px-3 py-2.5 font-semibold text-left text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Guest</th>
