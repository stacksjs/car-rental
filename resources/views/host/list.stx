            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#FF3E54" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h3 class="m-0 mb-2 text-3xl serif">You're all set.</h3>
          <p class="m-0 mb-6 mx-auto max-w-[44ch] text-[color:var(--text-muted)]">We'll verify your info and publish your listing within 24 hours. You can preview it any time from your host dashboard.</p>
          <div class="flex flex-wrap gap-2 justify-center">
            <button class="inline-flex gap-2 items-center px-6 py-3.5 font-semibold text-[0.9375rem] text-white bg-[#FF3E54] hover:bg-[#e63349] border-0 rounded-xl disabled:opacity-60 transition-all cursor-pointer disabled:cursor-not-allowed hover:-translate-y-px"
                    style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)"
                    :disabled="isPublishing()" @click="publish()">
              <span :show="!isPublishing()">Publish listing</span>
              <span :show="isPublishing()" class="inline-flex gap-2 items-center"><span style="display:inline-block; width: 16px; height: 16px; border: 2px solid white; border-top-color: transparent; border-radius: 50%; animation: spin 0.7s linear infinite"></span> Publishing...</span>
            </button>
          </div>
        </div>
      </section>

    </div>
  </section>

</div>

<style>@keyframes spin { to { transform: rotate(360deg); } }</style>

<script client>
  // Draft persistence — `useLocalStorage` gives us a signal that syncs to
  // localStorage, so refreshing mid-wizard preserves form values. Photos
  // aren't persisted (blob URLs expire on reload) but every text field is.
  const draft = useLocalStorage('drivly-host-draft', {
    step: 1, year: 2026, make: '', model: '', trim: '', plate: '', vin: '',
    price: 89, smartPricing: false, instantBook: true, offerDelivery: false,
    pickupLoc: '1247 Elm Street, Austin, TX', earliestTime: '8:00 AM',
    availableDays: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
    houseRules: '',
  })
  const d = draft()

  // ── All wizard state lives here. Inputs use x-model, the rest derive. ──
  const step         = state(d.step || 1)
  const wYear        = state(d.year)
  const wMake        = state(d.make)
  const wModel       = state(d.model)
  const wTrim        = state(d.trim)
  const wPlate       = state(d.plate)
  const wVin         = state(d.vin)
  // File uploads → blob URLs, indexed by slot. Not persisted (blob URLs don't
  // survive reload); users would re-upload on refresh.
  const photos       = state(Array(6).fill(null))
  const price        = state(d.price)
  const smartPricing = state(d.smartPricing)
  const instantBook  = state(d.instantBook)
  const offerDelivery = state(d.offerDelivery)
  const pickupLoc    = state(d.pickupLoc)
  const earliestTime = state(d.earliestTime)
  // Weekdays — Set signal for toggling; serialized as array for localStorage.
  const availableDays = state(new Set(d.availableDays || ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']))
  const houseRules   = state(d.houseRules)
  const isPublishing = state(false)

  // Keep localStorage in sync with every signal change. One effect covers all
  // fields — useLocalStorage writes are debounced internally.
  effect(() => {
    draft.set({
      step: step(), year: wYear(), make: wMake(), model: wModel(), trim: wTrim(),
      plate: wPlate(), vin: wVin(), price: price(),
      smartPricing: smartPricing(), instantBook: instantBook(), offerDelivery: offerDelivery(),
      pickupLoc: pickupLoc(), earliestTime: earliestTime(),
      availableDays: Array.from(availableDays()),
      houseRules: houseRules(),
    })
  })

  const STEP_TITLES = {{ stepTitles }}

  // ── Derived labels — every "$123" in the UI comes from one of these. ──
  const stepTitle        = derived(() => STEP_TITLES[step()] || '')
  const projGross        = derived(() => '$' + (Number(price()) * 12).toLocaleString())
  const projFee          = derived(() => '-$' + (Number(price()) * 12 * 0.15).toLocaleString())
  const projNet          = derived(() => '$' + (Number(price()) * 12 * 0.85).toLocaleString())
  const earningsEstimate = derived(() => '$' + Math.round(Number(price()) * 12 * 0.85).toLocaleString())

  // ── Actions. ──
  function nextFromStep1() {
    if (!wMake() || !wModel() || wVin().length < 11) {
      window._toast && window._toast('Fill in make, model, and VIN', 'error')
      return
    }
    step.set(2)
  }

  function onPhotoPicked(idx, e) {
    const f = e.target.files && e.target.files[0]
    if (!f) return
    const next = [...photos()]
    next[idx] = URL.createObjectURL(f)
    photos.set(next)
  }

  function toggleDay(day) {
    const s = new Set(availableDays())
    if (s.has(day)) s.delete(day); else s.add(day)
    availableDays.set(s)
  }

  function publish() {
    isPublishing.set(true)
    setTimeout(() => {
      isPublishing.set(false)
      // Clear the draft — user successfully published, no reason to keep it.
      try { localStorage.removeItem('drivly-host-draft') } catch {}
      window._toast && window._toast('Listing submitted! We\'ll review within 24h.', 'success')
      try { window.navigate && window.navigate('/host/dashboard') } catch (e) { location.href = '/host/dashboard' }
    }, 1400)
  }
</script>

@endsection
