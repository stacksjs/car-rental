    <div class="p-8">

      <!-- STEP 1: Car basics -->
      <section class="animate-fade-in" :show="step() === 1">
        <div class="grid gap-5 grid-cols-1 md:grid-cols-2">
          <label><span class="block mb-1.5 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Year *</span>
            <select class="px-4 py-3 w-full text-sm border rounded-xl bg-[color:var(--input-bg)] border-[color:var(--border)] text-[color:var(--text)]" x-model="wYear">
