            <label class="flex gap-2 items-center mt-2.5 text-sm cursor-pointer">
              <input type="checkbox" class="h-4 w-4" style="accent-color: #FF3E54" x-model="instantBook"> Enable Instant Book
            </label>
            <label class="flex gap-2 items-center mt-2.5 text-sm cursor-pointer">
              <input type="checkbox" class="h-4 w-4" style="accent-color: #FF3E54" x-model="offerDelivery"> Offer delivery (+$49/trip)
