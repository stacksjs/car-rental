              <div class="flex flex-col gap-1.5 items-center" :show="!photos()[{{ idx }}]">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7v7M10 14L21 3M21 14v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"/></svg>
                <span class="text-xs">Upload</span>
              </div>
            </label>
          @endforeach
        </div>

        <div class="flex justify-between mt-8">
          <button class="px-6 py-3.5 font-semibold text-[0.9375rem] bg-transparent border rounded-xl transition-colors cursor-pointer border-[color:var(--border-strong)] text-[color:var(--text)] hover:bg-[color:var(--bg-subtle)]" @click="step.set(1)">Back</button>
          <button class="px-6 py-3.5 font-semibold text-[0.9375rem] text-white bg-[#FF3E54] hover:bg-[#e63349] border-0 rounded-xl transition-all cursor-pointer hover:-translate-y-px"
                  style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)"
                  @click="step.set(3)">Next</button>
        </div>
      </section>

      <!-- STEP 3: Pricing -->
      <section class="animate-fade-in" :show="step() === 3">
