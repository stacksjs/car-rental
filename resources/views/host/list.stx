    <!-- Progress bar — width bound to step signal -->
    <div class="relative h-[3px] bg-[color:var(--bg-muted)]">
      <div class="absolute left-0 top-0 h-full bg-[#FF3E54] duration-300 transition-[width]"
           :attr:style="'width: ' + (step() * 20) + '%'"></div>
