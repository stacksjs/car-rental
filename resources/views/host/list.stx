              <span class="text-[color:var(--text-muted)]">Gross earnings</span>
              <span class="tabular" :text="projGross">$—</span>
            </div>
            <div class="flex justify-between mb-2 text-sm">
              <span class="text-[color:var(--text-muted)]">Drivly fee (15%)</span>
              <span class="tabular" :text="projFee">$—</span>
            </div>
            <div class="flex justify-between mt-2 pt-2 font-bold text-sm border-t border-[color:var(--border)]">
              <span>You keep</span>
              <span class="tabular" :text="projNet">$—</span>
            </div>
          </div>
        </div>

        <div class="flex justify-between mt-8">
          <button class="px-6 py-3.5 font-semibold text-[0.9375rem] bg-transparent border rounded-xl transition-colors cursor-pointer border-[color:var(--border-strong)] text-[color:var(--text)] hover:bg-[color:var(--bg-subtle)]" @click="step.set(2)">Back</button>
          <button class="px-6 py-3.5 font-semibold text-[0.9375rem] text-white bg-[#FF3E54] hover:bg-[#e63349] border-0 rounded-xl transition-all cursor-pointer hover:-translate-y-px"
                  style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)"
                  @click="step.set(4)">Next</button>
        </div>
      </section>

      <!-- STEP 4: Availability -->
      <section class="animate-fade-in" :show="step() === 4">
        <p class="m-0 mb-5 text-[color:var(--text-muted)]">Mark the days you're generally unavailable. You can always update later.</p>

        <div class="grid gap-4 grid-cols-1 md:grid-cols-2">
          <label><span class="block mb-1.5 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Pickup location</span>
            <input class="px-4 py-3 w-full text-sm border rounded-xl bg-[color:var(--input-bg)] border-[color:var(--border)] text-[color:var(--text)]" x-model="pickupLoc" placeholder="Street address"></label>
          <label><span class="block mb-1.5 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Earliest pickup time</span>
            <select class="px-4 py-3 w-full text-sm border rounded-xl bg-[color:var(--input-bg)] border-[color:var(--border)] text-[color:var(--text)]" x-model="earliestTime">
              @foreach (earliestTimes as t)
                <option>{{ t }}</option>
              @endforeach
            </select>
          </label>
        </div>

        <div class="mt-6">
          <span class="block mb-1.5 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Typical weekly availability</span>
          <div class="flex flex-wrap gap-2">
            @foreach (daysOfWeek as day)
              <button class="px-4 py-2.5 font-medium text-sm border-[1.5px] rounded-xl transition-all cursor-pointer select-none"
                      :class="{ 'bg-[color:var(--text)] text-[color:var(--bg)] border-[color:var(--text)]': availableDays().has('{{ day }}'), 'bg-transparent text-[color:var(--text)] border-[color:var(--border)] hover:bg-[color:var(--bg-hover)]': !availableDays().has('{{ day }}') }"
                      @click="toggleDay('{{ day }}')">{{ day }}</button>
            @endforeach
          </div>
        </div>

        <label class="block mt-6">
          <span class="block mb-1.5 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">House rules & notes (optional)</span>
          <textarea class="px-4 py-3 w-full text-sm border rounded-xl bg-[color:var(--input-bg)] border-[color:var(--border)] text-[color:var(--text)]"
                    rows="4" placeholder="e.g. No smoking. Please return with same fuel level." x-model="houseRules"></textarea>
        </label>

        <div class="flex justify-between mt-8">
          <button class="px-6 py-3.5 font-semibold text-[0.9375rem] bg-transparent border rounded-xl transition-colors cursor-pointer border-[color:var(--border-strong)] text-[color:var(--text)] hover:bg-[color:var(--bg-subtle)]" @click="step.set(3)">Back</button>
          <button class="px-6 py-3.5 font-semibold text-[0.9375rem] text-white bg-[#FF3E54] hover:bg-[#e63349] border-0 rounded-xl transition-all cursor-pointer hover:-translate-y-px"
                  style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)"
                  @click="step.set(5)">Next</button>
