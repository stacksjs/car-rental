<script server>
const pageTitle = 'Drive a relocation · Drivly'
const pageDescription = 'Get paid to drive a car from city to city. Hosts pay flat or per-mile, plus fuel.'
const activePage = 'relocations'

useSeoMeta({
  title: pageTitle,
  description: pageDescription,
  ogTitle: 'Drive a car for cash — Drivly Relocations',
  ogDescription: pageDescription,
  ogType: 'website',
  twitterCard: 'summary_large_image',
})

// Surface labels — drives both the filter pills and the per-row badges
const compensationLabels = {
  flat: 'Flat fee',
  per_mile: 'Per mile',
  free: 'Free use',
}

const sortOptions = [
  { value: 'newest', label: 'Newest' },
  { value: 'payHigh', label: 'Pay (high → low)' },
  { value: 'payLow', label: 'Pay (low → high)' },
  { value: 'soonest', label: 'Pickup soonest' },
]
</script>

@extends('layouts/app.stx')

@section('content')

