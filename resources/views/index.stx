<!-- ── APP CTA ──────────────────────────────────────────
     Two-column at lg: copy on the left, stylised phone on the right.
     Sizing is tuned so the copy block and the phone are roughly the same
     visual height — otherwise `items-center` would leave lots of empty
     space on one side. Phone stroke is darkened so the frame reads on
     the light `bg-subtle` panel. -->
<section class="pb-20 py-12">
  <div class="mx-auto px-6 max-w-[1280px]">
    <div class="grid overflow-hidden gap-12 grid-cols-1 items-center lg:gap-16 lg:grid-cols-[1.15fr_1fr] p-10 sm:p-14 lg:p-16 border rounded-3xl bg-[color:var(--bg-subtle)] border-[color:var(--border)]">
      <!-- Left: copy + CTAs. Max-width keeps line length readable even
           when the column grows wide. -->
      <div class="max-w-[560px]">
        <span class="inline-flex gap-1.5 items-center px-3 py-1.5 font-semibold text-[#FF3E54] text-xs tracking-wide uppercase bg-[rgba(255,62,84,0.1)] border border-[rgba(255,62,84,0.25)] rounded-full">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          New · iOS & Android
        </span>
        <h2 class="m-0 mb-4 mt-4 leading-[1.02] text-4xl tracking-tight sm:text-5xl lg:text-6xl serif">Drive smarter from your pocket.</h2>
        <p class="m-0 mb-8 max-w-[48ch] leading-relaxed text-lg text-[color:var(--text-muted)]">Unlock cars without swapping keys, message hosts in-thread, and track pickup times — all from the Drivly app.</p>

        <!-- Store buttons: both fixed-width + same internal row layout so
             the Apple and Google glyphs optically align. `items-center`
             on the outer flex vertically centers icon against the
             two-line label block. -->
        <div class="flex flex-wrap gap-3 items-center">
          <a href="#" class="inline-flex gap-3 items-center px-5 h-14 no-underline text-white bg-[#0a0a0a] rounded-2xl transition-transform hover:-translate-y-px">
            <svg width="24" height="24" viewBox="0 0 384 512" fill="currentColor" aria-hidden="true" class="shrink-0"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zM282.1 87.2c19.7-23.4 29.4-51.6 26.3-80.1-24.9 1.6-52 18-72.8 40.7-18.9 20.5-29.6 49.7-26.1 77.9 24.2 1.5 48-10.3 72.6-38.5z"/></svg>
            <span class="flex flex-col leading-none">
              <span class="mb-1 font-normal text-[0.625rem] opacity-75">Download on the</span>
              <span class="font-semibold text-base tracking-tight">App Store</span>
            </span>
          </a>
          <a href="#" class="inline-flex gap-3 items-center px-5 h-14 no-underline text-white bg-[#0a0a0a] rounded-2xl transition-transform hover:-translate-y-px">
            <svg width="22" height="24" viewBox="0 0 24 24" aria-hidden="true" class="shrink-0">
              <path fill="#34a853" d="M3 20.5V3.5c0-.34.09-.66.24-.93l10.5 10.5-10.5 10.46C3.09 21.16 3 20.84 3 20.5z"/>
              <path fill="#fbbc05" d="M17.47 11.95l-3.73-3.73L4.06 2.36l12.66 9.24.75.35z"/>
              <path fill="#ea4335" d="M17.47 12.05l-.75.55L4.06 21.64l9.68-5.86 3.73-3.73z"/>
              <path fill="#4285f4" d="M21.5 10.88l-3.2-1.82-3.56 3.03L18.3 15l3.2-1.82c.96-.55.96-1.75 0-2.3z"/>
            </svg>
            <span class="flex flex-col leading-none">
              <span class="mb-1 font-normal text-[0.625rem] opacity-75">Get it on</span>
              <span class="font-semibold text-base tracking-tight">Google Play</span>
            </span>
          </a>
        </div>

        <!-- Reviews line, tucked under the buttons with matched rhythm. -->
        <div class="flex gap-2 items-center mt-6 text-sm text-[color:var(--text-muted)]">
          <span class="text-[#f5a623] tracking-tight" aria-hidden="true">★★★★★</span>
          <span><strong class="text-[color:var(--text)]">4.8</strong> · 52k reviews on iOS & Android</span>
        </div>
      </div>

      <!-- Right: decorative phone mock. Stroke darkened + drop shadow so
           the silhouette reads clearly on the light panel. Height tuned
           to roughly match the copy stack. -->
      <div class="flex relative items-center justify-center lg:justify-end">
        <svg viewBox="0 0 280 540" class="h-auto max-w-[260px] w-full drop-shadow-2xl" aria-hidden="true">
          <defs>
            <linearGradient id="phone-bg" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#FF3E54"/>
              <stop offset="100%" stop-color="#7c3aed"/>
            </linearGradient>
          </defs>
          <!-- Outer phone body -->
          <rect x="10" y="10" width="260" height="520" rx="40" fill="#0a0a0d" stroke="#1a1a1d" stroke-width="1"/>
          <!-- Inner bezel for depth -->
          <rect x="18" y="18" width="244" height="504" rx="34" fill="url(#phone-bg)"/>
          <!-- Dynamic island / notch -->
          <rect x="112" y="28" width="56" height="16" rx="8" fill="#0a0a0d"/>
          <!-- Status bar time placeholder -->
