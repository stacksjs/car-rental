<!-- @memo: pure static marketing content — memoize so SPA nav doesn't re-render. -->
@memo([])
<section class="py-16">
  <div class="mx-auto px-6 max-w-[1280px]">
    <div class="mb-12 mx-auto max-w-[640px] text-center">
      <span class="inline-flex gap-1.5 items-center px-2.5 py-1.5 font-medium text-xs border rounded-full bg-[color:var(--bg-subtle)] border-[color:var(--border)] text-[color:var(--text-secondary)]">How it works</span>
      <h2 class="m-0 mb-2 mt-4 text-4xl sm:text-5xl serif">The simplest way to rent a car</h2>
      <p class="m-0 text-lg text-[color:var(--text-muted)]">It takes under 60 seconds. Really.</p>
    </div>

    <div class="grid gap-5 grid-cols-1 md:grid-cols-3">
      @foreach (steps as step)
        <div class="overflow-hidden relative p-8 border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
          <div class="absolute right-5 top-5 font-bold text-xs tracking-wider text-[color:var(--text-faint)]">{{ step.num }}</div>
          <div class="flex items-center justify-center mb-5 h-14 w-14 text-3xl bg-[rgba(255,62,84,0.1)] rounded-2xl">{{ step.icon }}</div>
          <h3 class="m-0 mb-2 text-2xl serif">{{ step.title }}</h3>
          <p class="m-0 leading-relaxed text-[color:var(--text-muted)]">{{ step.desc }}</p>
        </div>
      @endforeach
    </div>
  </div>
</section>
@endmemo

