<script server>
import { cars, categories, cities } from '../data/cars'

const pageTitle = 'Drivly — Rent unique cars from real people'
const pageDescription = 'Skip the rental counter. Book from 350,000+ hosts across 10,000+ cities. Teslas, Jeeps, classic Mustangs, and more.'
const activePage = 'home'

// Full SEO payload: title, description, Open Graph, Twitter card. stx's
// `useSeoMeta` merges these into the <head> at render time — the layout
// picks them up automatically via `@stack('head')` internally.
useSeoMeta({
  title: pageTitle,
  description: pageDescription,
  ogTitle: 'Drivly — the car marketplace',
  ogDescription: pageDescription,
  ogImage: cars[0].image,
  ogType: 'website',
  ogUrl: 'https://drivly.example/',
  twitterCard: 'summary_large_image',
  twitterTitle: pageTitle,
  twitterDescription: pageDescription,
  twitterImage: cars[0].image,
})

const featured = cars.slice(0, 4)
const deals = cars.filter(c => c.originalPrice).slice(0, 3)
const luxury = cars.filter(c => c.category === 'Luxury' || c.category === 'Sports' || c.category === 'Convertible').slice(0, 4)

const stats = [
  { label: 'Cities', value: '10,000+' },
  { label: 'Cars listed', value: '350,000+' },
  { label: 'Average host earnings', value: '$10,516' },
  { label: 'Trips completed', value: '14M+' },
]

const steps = [
  { num: '01', title: 'Find the perfect car', desc: 'Browse by make, price, or vibe. Filter to exactly what you need — from a grocery-getter to a weekend cruiser.', icon: '🔍' },
  { num: '02', title: 'Book in a click', desc: 'Instant Book gets you on the road in minutes. No counter, no fine print, no games.', icon: '⚡' },
  { num: '03', title: 'Meet or unlock & go', desc: 'Hosts hand off keys in person or via contactless unlock with the app. Return the same way.', icon: '🔑' },
]

const testimonials = [
  { name: 'Maya L.', role: 'Guest · New York', body: 'Booked a Model 3 for a trip up the Hudson. It was cheaper than renting, cooler than Uber, and the host was a gem.', rating: 5 },
  { name: 'Darren C.', role: 'Host · Austin',   body: 'I make ~$1,200/mo off my second car. Pays my rent. Guests have been lovely, and Drivly handles everything insurance-wise.', rating: 5 },
  { name: 'Priya S.',  role: 'Guest · LA',      body: 'Found a convertible AMG for our anniversary. Top down on PCH was unreal. Easily the most memorable date we\'ve had.', rating: 5 },
]

const popularSearches = ['Tesla', 'Jeep Wrangler', 'Convertible', 'SUVs with 7 seats', 'Under $75/day', 'EVs']
</script>

@extends('layouts/app.stx')

@section('content')

