    <div class="absolute bottom-[-100px] left-[-80px] h-[400px] w-[400px] rounded-full blur-3xl"
         style="background: radial-gradient(circle, rgba(147, 51, 234, 0.14) 0%, transparent 70%)"></div>
  </div>

  <div class="mx-auto px-6 max-w-[1280px]">
