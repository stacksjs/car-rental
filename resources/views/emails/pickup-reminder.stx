<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="font-family: -apple-system, BlinkMacSystemFont, sans-serif; color: #111;">
  <div style="max-width: 540px; margin: 32px auto; padding: 24px; border: 1px solid #eee; border-radius: 12px;">
    <h1 style="color: #FF3E54;">Your pickup is tomorrow</h1>
    <p>Reference: <strong>{{ reference }}</strong></p>
    <p>Pickup: <strong>{{ start }}</strong> at {{ pickupTime }}</p>
  </div>
</body>
</html>
