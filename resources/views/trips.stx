</div>

<script client>
  const tab = state('upcoming')
  const liveUpcoming = state(null)
  const livePast = state(null)
  const liveCancelled = state(null)

  effect(async () => {
    const token = localStorage.getItem('drivly-token')
    if (!token) return
    try {
      const res = await fetch('/api/bookings/mine', { headers: { Authorization: 'Bearer ' + token } })
      if (!res.ok) return
      const body = await res.json()
      liveUpcoming.set(body.upcoming || [])
      livePast.set(body.past || [])
      liveCancelled.set(body.cancelled || [])
    } catch { /* noop */ }
  })

  function messageHost() { window._toast && window._toast('Host contacted', 'success') }
  function rebook()      { window._toast && window._toast('Rebooking this car...', 'info') }
</script>

@endsection
