          <div class="text-right">
            <p class="m-0 font-semibold tabular">${{ trip.total.toFixed(2) }}</p>
            <button class="mt-2.5 px-3.5 py-2 font-medium text-[0.8125rem] bg-transparent border-0 rounded-lg transition-colors cursor-pointer text-[color:var(--text)] hover:bg-[color:var(--bg-hover)]"
