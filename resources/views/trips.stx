          <div class="overflow-hidden rounded-xl bg-[color:var(--bg-muted)]" style="aspect-ratio: 16/11">
            <img src="{{ trip.car.image }}" alt="{{ trip.car.year }} {{ trip.car.make }} {{ trip.car.model }}" loading="lazy" decoding="async" class="object-cover h-full w-full" style="filter: saturate(0.8)">
          </div>
          <div>
