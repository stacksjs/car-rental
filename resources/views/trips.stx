  <!-- Cancelled -->
  <section class="px-4 py-16 text-center" :show="tab() === 'cancelled'">
    <p class="m-0 mb-2 text-5xl">✨</p>
    <h3 class="m-0 text-2xl serif">No cancellations. Nice.</h3>
