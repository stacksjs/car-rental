<script server>
const pageTitle = 'Earnings calculator · Drivly'
const activePage = 'earnings'

useSeoMeta({
  title: 'Earnings calculator — Drivly',
  description: 'Estimate what your car could earn on Drivly. Based on local market rates and real host performance.',
})

// Preset defaults that hint at what drives earnings. The client-side
// calculator recomputes in real-time based on user input.
const defaultCity = 'San Francisco, CA'
const defaultCar = '2023 Tesla Model 3'

const examples = [
  { car: 'Tesla Model 3',   city: 'San Francisco, CA', trips: '14/mo', annual: '$14,280' },
  { car: 'Jeep Wrangler',   city: 'Denver, CO',        trips: '11/mo', annual: '$11,550' },
  { car: 'Honda Civic',     city: 'Austin, TX',        trips: '16/mo', annual: '$8,640' },
  { car: 'Porsche 911',     city: 'Miami, FL',         trips: '7/mo',  annual: '$26,040' },
  { car: 'Toyota Camry',    city: 'Chicago, IL',       trips: '12/mo', annual: '$7,920' },
  { car: 'Ford F-150',      city: 'Phoenix, AZ',       trips: '10/mo', annual: '$10,800' },
]

const factors = [
  { icon: '📍', title: 'Location', body: 'Airports, downtowns, and resort cities earn the most. We show median prices for your zip code when you list.' },
  { icon: '🚗', title: 'Vehicle type', body: 'EVs and SUVs are in highest demand. Luxury cars earn more per trip; economy earns more per month via volume.' },
  { icon: '📅', title: 'Availability', body: 'Cars available 25+ days a month earn 2.3× more than part-time listings. Instant Book boosts bookings 40%.' },
  { icon: '⭐', title: 'Reviews', body: 'A 4.9+ rating unlocks premium placement. Hosts above 4.9 earn 60% more than hosts at 4.5.' },
]
</script>

@extends('layouts/app.stx')

