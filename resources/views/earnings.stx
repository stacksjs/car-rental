        </label>
        <label>
          <span class="block mb-2 font-semibold text-xs tracking-wider uppercase text-[color:var(--text-muted)]">Daily rate: $<span :text="price">89</span></span>
          <input type="range" min="25" max="450" value="89" x-model="price" class="w-full accent-[#FF3E54]">
