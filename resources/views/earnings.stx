<script client>
  const city = state('{{ defaultCity }}')
  const carName = state('{{ defaultCar }}')
  const price = state(89)
  const daysPerWeek = state(3)

  const monthly = derived(() => {
    const p = Number(price())
    const d = Number(daysPerWeek())
    // 12% utilization bump for higher price + availability curve
    const monthlyDays = d * 4.33
    const gross = p * monthlyDays
    return Math.round(gross * 0.85) // 15% fee
  })
  const gross = derived(() => Math.round(Number(price()) * Number(daysPerWeek()) * 4.33))
  const fee = derived(() => Math.round(gross() * 0.15))

  const fmtMoney = (n) => '$' + n.toLocaleString()
  const monthlyLabel = derived(() => fmtMoney(monthly()))
  const grossLabel   = derived(() => fmtMoney(gross()))
  const feeLabel     = derived(() => '-' + fmtMoney(fee()))
  const annualLabel  = derived(() => fmtMoney(monthly() * 12))
</script>
@endsection
