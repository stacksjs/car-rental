    <h1 class="m-0 mb-4 mx-auto max-w-[20ch] leading-[1.05] text-5xl sm:text-6xl lg:text-7xl serif">A better way to rent a car.</h1>
    <p class="mx-auto max-w-[52ch] leading-relaxed text-lg text-[color:var(--text-secondary)]">No long lines. No fine print. No upsells. Just you, a car, and the road.</p>
  </div>

  <section class="mb-20">
    <div class="flex flex-col gap-16">
      <div class="grid gap-12 grid-cols-1 items-center md:grid-cols-2">
        <div>
          <span class="inline-flex gap-1.5 items-center mb-3 px-2.5 py-1.5 font-medium text-xs border rounded-full bg-[color:var(--bg-subtle)] border-[color:var(--border)] text-[color:var(--text-secondary)]">01 · Browse</span>
          <h2 class="m-0 mb-3 text-3xl sm:text-4xl serif">Find exactly what you want</h2>
          <p class="m-0 leading-relaxed text-base text-[color:var(--text-muted)]">Over 350,000 cars from real people. Filter by make, price, features, fuel type — whatever you need. Then zoom in on the photos, reviews, and host info.</p>
        </div>
        <div class="overflow-hidden bg-center bg-cover border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]" style="aspect-ratio: 4/3; background-image: url('https://images.unsplash.com/photo-1494976388531-d1058494cdd8?auto=format&fit=crop&w=1200&q=70')"></div>
      </div>

      <div class="grid gap-12 grid-cols-1 items-center md:grid-cols-2">
        <div class="order-first overflow-hidden md:order-none bg-center bg-cover border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]" style="aspect-ratio: 4/3; background-image: url('https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?auto=format&fit=crop&w=1200&q=70')"></div>
        <div>
          <span class="inline-flex gap-1.5 items-center mb-3 px-2.5 py-1.5 font-medium text-xs border rounded-full bg-[color:var(--bg-subtle)] border-[color:var(--border)] text-[color:var(--text-secondary)]">02 · Book</span>
          <h2 class="m-0 mb-3 text-3xl sm:text-4xl serif">Book in minutes</h2>
          <p class="m-0 leading-relaxed text-base text-[color:var(--text-muted)]">Instant Book gets you on the road immediately. Otherwise, hosts typically respond in under an hour. Your card isn't charged until the host confirms.</p>
        </div>
      </div>

      <div class="grid gap-12 grid-cols-1 items-center md:grid-cols-2">
        <div>
          <span class="inline-flex gap-1.5 items-center mb-3 px-2.5 py-1.5 font-medium text-xs border rounded-full bg-[color:var(--bg-subtle)] border-[color:var(--border)] text-[color:var(--text-secondary)]">03 · Drive</span>
          <h2 class="m-0 mb-3 text-3xl sm:text-4xl serif">Meet & go — or unlock with your phone</h2>
          <p class="m-0 leading-relaxed text-base text-[color:var(--text-muted)]">Hosts either meet you personally or unlock the car remotely via the Drivly app. Return the same way. Take a deep breath and enjoy.</p>
        </div>
        <div class="overflow-hidden bg-center bg-cover border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]" style="aspect-ratio: 4/3; background-image: url('https://images.unsplash.com/photo-1552519507-da3b142c6e3d?auto=format&fit=crop&w=1200&q=70')"></div>
      </div>
    </div>
  </section>

  <section class="mb-20">
    <h2 class="m-0 mb-1.5 text-4xl text-center sm:text-5xl serif">Trust & safety built in</h2>
    <p class="m-0 mb-10 text-center text-[color:var(--text-muted)]">Every trip backed by real protection.</p>

    <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 md:grid-cols-4">
      @foreach (trustFacts as fact)
        <div class="p-6 text-center border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
          <p class="m-0 mb-2 text-3xl">{{ fact.icon }}</p>
          <h3 class="m-0 mb-1.5 font-bold text-base">{{ fact.title }}</h3>
          <p class="m-0 leading-relaxed text-sm text-[color:var(--text-muted)]">{{ fact.desc }}</p>
        </div>
      @endforeach
    </div>
  </section>

  <section class="mb-20">
    <h2 class="m-0 mb-1.5 text-4xl text-center sm:text-5xl serif">Frequently asked</h2>
    <p class="m-0 mb-10 text-center text-[color:var(--text-muted)]">Still have questions? <a href="#" class="font-semibold text-[#FF3E54]">Contact us →</a></p>

    <!-- @memo: the FAQ list is static and re-rendering it is wasted work on
         SPA navigation. @memo caches the subtree once per distinct dep value.
         Empty deps = never re-render. -->
    @memo([])
    <div class="flex flex-col gap-2.5">
      @foreach (faq as item)
        <details class="overflow-hidden border rounded-2xl bg-[color:var(--bg-elevated)] border-[color:var(--border)]">
          <summary class="flex items-center justify-between px-6 py-4.5 font-semibold list-none text-base cursor-pointer">
            <span>{{ item.q }}</span>
            <svg class="h-4 w-4 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="pb-5 px-6 leading-relaxed text-[0.9375rem] text-[color:var(--text-secondary)]">{{ item.a }}</div>
        </details>
      @endforeach
    </div>
    @endmemo
  </section>

  <section class="mb-12 p-12 sm:p-16 text-center border rounded-3xl" style="background: linear-gradient(135deg, rgba(255,62,84,0.1) 0%, rgba(147,51,234,0.08) 100%); border-color: rgba(255,62,84,0.25)">
    <h2 class="m-0 mb-4 text-4xl sm:text-5xl serif">Ready to roll?</h2>
    <p class="m-0 mb-10 mx-auto max-w-[38ch] leading-relaxed text-lg text-[color:var(--text-muted)]">Millions are already driving better. You're next.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <StxLink to="/search" class="inline-flex gap-2 items-center px-6 py-3.5 font-semibold text-[0.9375rem] text-white bg-[#FF3E54] hover:bg-[#e63349] rounded-xl transition-all hover:-translate-y-px"
               style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)">Browse cars</StxLink>
      <StxLink to="/host/list" class="inline-flex gap-2 items-center px-6 py-3.5 font-semibold text-[0.9375rem] bg-transparent border rounded-xl transition-colors border-[color:var(--border-strong)] text-[color:var(--text)] hover:bg-[color:var(--bg-subtle)]">List your car</StxLink>
    </div>
  </section>

</div>

